# ====== 生产环境配置 ======
# 复制此文件为 .env.docker 并修改敏感信息

NODE_ENV=production
PORT=3001

# JWT 配置（请务必修改密钥）
JWT_SECRET=your-production-secret-key-change-this
JWT_EXPIRES_IN=7d

# 数据库配置（Docker 内部网络，无需修改主机和端口）
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme123
DB_NAME=inventory_system

# 日志级别
LOG_LEVEL=error
